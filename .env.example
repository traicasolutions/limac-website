# ─── Anthropic (AI Chatbot) ───────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Resend (Email Notifications) ────────────────────────────────────────────
# Get your key at: https://resend.com/
RESEND_API_KEY=

# ─── Payload CMS ─────────────────────────────────────────────────────────────
# A long random secret string (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Full URL where Payload admin is served (no trailing slash)
PAYLOAD_URL=http://localhost:3000

# Server-to-server Payload API key (created in Payload admin under API Keys)
PAYLOAD_API_KEY=

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Connection string from your Atlas cluster (include DB name at the end)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/limac?retryWrites=true&w=majority

# ─── Site ─────────────────────────────────────────────────────────────────────
# Production URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.limac.in

# ─── Product Data Source ──────────────────────────────────────────────────────
# csv    = read products from public/product/products.csv (default)
# cms    = read products from Payload CMS / MongoDB
# hybrid = read CSV first, then append non-duplicate products from CMS
PRODUCT_DATA_SOURCE=csv
